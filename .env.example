# Database Connection
DATABASE_URL=postgresql://username:password@localhost:5432/topical

# Kinde Authentication (https://kinde.com)
KINDE_DOMAIN=https://your-app.kinde.com
KINDE_CLIENT_ID=your-client-id
KINDE_CLIENT_SECRET=your-client-secret
KINDE_REDIRECT_URI=http://localhost:5173/api/callback
KINDE_LOGOUT_REDIRECT_URI=http://localhost:5173

# Gemini API key is configured in the web UI under Profile → AI Settings
# No need to set it here — each user provides their own key

# AI Content Service (FastAPI Python backend)
RAG_SERVICE_URL=http://127.0.0.1:8000
